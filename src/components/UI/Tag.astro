---
export interface Props {
  href?: string;
  variant?: 'default' | 'accent' | 'teal';
}

const { href, variant = 'default' } = Astro.props;

const Tag = href ? 'a' : 'span';
---

<Tag
  href={href}
  class:list={[
    'tag',
    variant !== 'default' && `tag-${variant}`,
  ]}
>
  <slot />
</Tag>
