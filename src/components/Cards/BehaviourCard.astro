---
export interface Props {
  title: string;
  description: string;
  href?: string;
}

const { title, description, href } = Astro.props;
---

<div class="behaviour-card">
  <h3>{href ? <a href={href}>{title}</a> : title}</h3>
  <p>{description}</p>
</div>

<style>
  .behaviour-card {
    background: var(--color-paper);
    padding: var(--space-6);
    border-top: 3px solid var(--color-squirrel);
  }

  .behaviour-card h3 {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2);
    text-transform: none;
    letter-spacing: normal;
  }

  .behaviour-card h3 a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .behaviour-card h3 a:hover {
    color: var(--color-squirrel);
  }

  .behaviour-card p {
    color: var(--color-ink-light);
    margin: 0;
    font-size: var(--text-sm);
  }
</style>
