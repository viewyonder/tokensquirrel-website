---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Sections/Hero.astro';

const FALLBACK_IMAGE = '/images/tokensquirrel-cyber-hero.webp';

const all = await getCollection('blog');
const posts = all
  .filter((p) => (import.meta.env.PROD ? !p.data.draft : true))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<Layout
  title="Blog — TokenSquirrel"
  description="Posts and notes from the TokenSquirrel project."
>
  <Hero
    eyebrow="Blog"
    title="Notes from the project"
    description="Experiments, design notes, and progress reports."
    centered
  />

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p class="empty">Nothing published yet.</p>
      ) : (
        <div class="blog-grid">
          {posts.map((post) => {
            const img = post.data.heroImage ?? FALLBACK_IMAGE;
            const alt = post.data.heroImageAlt ?? post.data.title;
            return (
              <a class="blog-card" href={`/blog/${post.slug}`}>
                <div class="blog-card-image">
                  <img src={img} alt={alt} loading="lazy" />
                </div>
                <div class="blog-card-body">
                  <span class="blog-card-meta">
                    {dateFmt.format(post.data.pubDate)}
                    {post.data.draft && <span class="draft-tag"> · draft</span>}
                  </span>
                  <h2>{post.data.title}</h2>
                  {post.data.description && <p>{post.data.description}</p>}
                  <span class="blog-card-cta">Read post →</span>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border: var(--border-thin);
    border-top: 3px solid var(--color-squirrel);
    text-decoration: none;
    color: var(--color-ink);
    transition: transform var(--transition-fast), border-color var(--transition-fast);
    overflow: hidden;
  }

  .blog-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-squirrel);
  }

  .blog-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-squirrel-bg);
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
  }

  .blog-card-meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-squirrel);
  }

  .draft-tag {
    color: var(--color-ink-light);
  }

  .blog-card h2 {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    margin: 0;
    text-transform: none;
    letter-spacing: normal;
  }

  .blog-card p {
    margin: 0;
    color: var(--color-ink-light);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .blog-card-cta {
    margin-top: auto;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-squirrel);
  }

  .empty {
    color: var(--color-ink-light);
  }

  @media (max-width: 768px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
